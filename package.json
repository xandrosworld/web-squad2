{
  "name": "squad2-uat-command-center",
  "version": "1.0.0",
  "private": true,
  "description": "Squad 2 UAT Dashboard with Railway Postgres persistence",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "check": "node --check server.js && node --check app.js",
    "check:workbook": "node scripts/check-workbook-schema.js",
    "check:hd-uat": "node scripts/check-hd-uat-mapping.js",
    "check:excel-formulas": "node scripts/check-excel-formulas.js",
    "check:automation": "node scripts/check-automation-rules.js",
    "check:daily-import": "node scripts/check-daily-import.js",
    "check:tester-mapping": "node scripts/check-tester-mapping.js",
    "check:work-kpi": "node scripts/check-work-kpi.js",
    "check:group-editor": "node scripts/check-group-editor-policy.js",
    "check:work-item-invariants": "node scripts/check-work-item-invariants.js",
    "check:work-item-export": "node scripts/check-work-item-export.js",
    "import:workbook:db": "node scripts/import-workbook-to-db.js",
    "sync:handoff-sections": "node scripts/sync-handoff-sections.js",
    "smoke:dashboard": "node scripts/smoke-dashboard.js",
    "smoke:ui": "node scripts/smoke-ui.js",
    "smoke:sitemap-ui": "node scripts/smoke-sitemap-ui.js",
    "smoke:rbac": "node scripts/smoke-rbac.js",
    "smoke:workplan": "node scripts/smoke-workplan.js",
    "migrate:work-order": "node scripts/migrate-work-item-order.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "playwright-core": "^1.60.0"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}

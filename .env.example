PORT=3000
DATABASE_URL=postgresql://postgres:password@localhost:5432/railway

# Optional but recommended before handing the app to customers.
APP_USER=admin
APP_PASSWORD=change-this-password
SESSION_SECRET=change-this-long-random-session-secret

# Gemini AI assistant. Set the same variables in Railway before using AI in production.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_MS=30000

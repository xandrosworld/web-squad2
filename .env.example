PORT=3000
DATABASE_URL=postgresql://postgres:password@localhost:5432/railway

# Optional but recommended before handing the app to customers.
APP_USER=admin
APP_PASSWORD=change-this-password
SESSION_SECRET=change-this-long-random-session-secret
APP_BASE_URL=https://your-service.up.railway.app

# Gmail deadline reminders. Create a Web application OAuth client in Google Cloud.
GMAIL_SENDER_EMAIL=maitanthanh1998@gmail.com
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=https://your-service.up.railway.app/api/email-notifications/oauth/callback
GMAIL_TOKEN_ENCRYPTION_KEY=change-this-separate-long-random-secret
DEADLINE_MANAGER_EMAILS=yenuth@bidv.com.vn
# Run in the existing web service at 01:00 UTC (08:00 Vietnam) every day.
DEADLINE_NOTIFICATION_SCHEDULER_ENABLED=false
DEADLINE_NOTIFICATION_RUN_UTC_HOUR=1

# Gemini AI assistant. Set the same variables in Railway before using AI in production.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_MS=30000
